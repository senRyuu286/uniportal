# .env.example
# Copy this file to .env and fill in your values.
# .env is gitignored — never commit it.

# ── PostgreSQL ──────────────────────────────────────────────────────────────────

# Name of the PostgreSQL database
POSTGRES_DB=uniportal

# PostgreSQL superuser username
POSTGRES_USER=uniportal_user

# PostgreSQL superuser password — change this to something strong
POSTGRES_PASSWORD=change_me_db_password

# Host port that PostgreSQL is exposed on (container internal port is always 5432)
POSTGRES_PORT=5432

# ── pgAdmin 4 ───────────────────────────────────────────────────────────────────

# Login email for the pgAdmin web UI
PGADMIN_EMAIL=admin@uniportal.com

# Login password for the pgAdmin web UI
PGADMIN_PASSWORD=change_me_pgadmin_password

# Host port that pgAdmin is exposed on
PGADMIN_PORT=5050

# ── NestJS Backend ──────────────────────────────────────────────────────────────

# Port the NestJS API listens on (inside the container and exposed to the host)
BACKEND_PORT=3000

# Secret used to sign short-lived JWT access tokens — use a long random string
JWT_ACCESS_SECRET=change_me_access_secret_min_32_chars

# Expiry duration for access tokens (e.g. 15m, 1h)
JWT_ACCESS_EXPIRES_IN=15m

# Secret used to sign long-lived JWT refresh tokens — must differ from access secret
JWT_REFRESH_SECRET=change_me_refresh_secret_min_32_chars

# Expiry duration for refresh tokens (e.g. 7d, 30d)
JWT_REFRESH_EXPIRES_IN=7d

# Allowed CORS origin — the URL the Angular dev server is served from
FRONTEND_URL=http://localhost:4200

# ── Angular Frontend ────────────────────────────────────────────────────────────

# Host port that the Angular dev server is exposed on
FRONTEND_PORT=4200